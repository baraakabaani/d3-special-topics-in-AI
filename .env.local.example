# Copy this file to .env.local — used by scripts running on your laptop (not inside Docker)
# .env.local is gitignored. Each teammate keeps their own copy.

MONGO_URI=mongodb://admin:changeme@localhost:27017
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=changeme123
QDRANT_COLLECTION=d2_chunks
# 380 words * ~1.3 tokens/word ≈ 494 tokens — stays under bge-small-en's 512 limit
CHUNK_SIZE=380
CHUNK_OVERLAP=50
