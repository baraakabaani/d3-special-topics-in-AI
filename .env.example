# ── Docker Compose credentials (loaded by compose automatically) ───────────
# Commit this file. Use real values only in .env (which is gitignored).

MONGO_USER=admin
MONGO_PASS=changeme
NEO4J_USER=neo4j
NEO4J_PASS=changeme123

# ── For host scripts (ingest.py, check_services.py, etc.) ──────────────────
# Copy the lines below into a new file called .env.local
# .env.local is gitignored — each teammate creates their own copy.
#
# MONGO_URI=mongodb://admin:changeme@localhost:27017
# QDRANT_URL=http://localhost:6333
# NEO4J_URI=bolt://localhost:7687
# QDRANT_COLLECTION=d2_chunks
# 380 words * ~1.3 tokens/word ≈ 494 tokens — stays under bge-small-en's 512 limit
# CHUNK_SIZE=380
# CHUNK_OVERLAP=50
